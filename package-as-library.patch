+[build-system]
+requires = ["setuptools>=61"]
+build-backend = "setuptools.build_meta"
+
+[project]
+name = "markov-cache"
+version = "0.1.0"
+description = "Toy global+cache Markov model: parametric memory vs. context window."
+readme = "README.md"
+requires-python = ">=3.9"
+license = { text = "MIT" }
+dependencies = ["numpy"]
+
+[project.optional-dependencies]
+# Plotting demos (demo_*.py). Not needed to import the library.
+demos = ["matplotlib"]
+# Interactive Streamlit GUI (gui_app.py).
+gui = ["streamlit", "matplotlib"]
+
+[project.urls]
+Homepage = "https://github.com/shumow/markov-models-aux-context-caching"
+
+[tool.setuptools]
+# Single-module library plus the real-text adapter. The demo_*/gui scripts are
